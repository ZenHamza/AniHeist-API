# path: .env.example
# Application
APP_NAME=Anime Stream Scraper
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
JSON_LOGGING=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_TTL=600
REDIS_HEALTH_TTL=30
REDIS_SEARCH_TTL=300
REDIS_ANIME_TTL=3600

# Playwright Browser Pool
MAX_BROWSERS=3
MAX_BROWSER_PAGES=100
BROWSER_RESTART_AFTER=50
PLAYWRIGHT_TIMEOUT=30000
NAVIGATION_TIMEOUT=15000
ELEMENT_WAIT_TIMEOUT=10000

# Circuit Breaker & Retry
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
MAX_RETRIES_PER_SOURCE=2
RETRY_BASE_DELAY=1.0
PER_SOURCE_TIMEOUT=30.0
TOTAL_REQUEST_TIMEOUT=45.0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Proxy (optional, JSON array of http/socks5 proxy URLs)
# PROXY_LIST=["http://user:pass@proxy1:8080","socks5://user:pass@proxy2:1080"]
PROXY_LIST=[]
PROXY_ROTATION_STRATEGY=round_robin

# BrightData residential proxy (alternative to PROXY_LIST — more reliable for Cloudflare bypass)
# Sign up at https://brightdata.com (≈$15/mo)
# BRIGHTDATA_USERNAME=your_username
# BRIGHTDATA_PASSWORD=your_password
# BRIGHTDATA_HOST=your_host.brightdata.io:22225

# Free HTTP/SOCKS proxies from TheSpeedX/PROXY-List (updated daily, ~7000+ proxies)
# These are datacenter proxies — may not bypass Cloudflare CDNs but worth trying.
# Enabled by default. Set to "false" to disable.
# USE_SPEEDX_PROXIES=true
# SPEEDX_MAX_PER_TYPE=100  # max HTTP + SOCKS4 + SOCKS5 proxies to load

# Free VPN proxy pool (from free-vpn-subscriptions output - VLESS/VMess/Trojan/SS)
# Requires sing-box binary in PATH. Set to "true" to enable.
# USE_FREE_PROXY_POOL=false
# SING_BOX_BIN=sing-box
# FREE_PROXY_DIR=/home/kali/Desktop/free-vpn-subscriptions/output

# Source URLs
ANIDB_BASE_URL=https://anidb.app
ANIZONE_BASE_URL=https://anizone.to
MIRURO_BASE_URL=https://www.miruro.to

# CORS
CORS_ORIGINS=["*"]
API_PREFIX=/api
